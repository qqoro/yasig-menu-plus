{
  "name": "yasig-menu-plus",
  "displayName": "야식메뉴판 Plus",
  "version": "1.15.3-beta.1",
  "description": "야식 관리에 도움이 되는 가벼운 앱",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qqoro/yasig-menu-plus.git"
  },
  "main": "main/main.js",
  "author": {
    "name": "qqoro"
  },
  "scripts": {
    "predev": "node scripts/rebuild-native.js",
    "dev": "node scripts/dev-server.js",
    "build": "tsc --noEmit && node scripts/build.js && electron-builder --win --publish=never",
    "build:port": "tsc --noEmit && node scripts/build.js && electron-builder --win portable --publish=never",
    "build:win": "tsc --noEmit && node scripts/build.js && electron-builder --win --publish=never",
    "build:port:win": "tsc --noEmit && node scripts/build.js && electron-builder --win portable --publish=never",
    "prepare": "husky",
    "postinstall": "node scripts/rebuild-native.js",
    "lint": "oxlint",
    "format": "prettier src/ --write",
    "type-check": "tsc --noEmit -p src/main/tsconfig.json && tsc --noEmit -p src/main/tsconfig.test.json && vue-tsc -p src/renderer/tsconfig.json --noEmit",
    "lint-staged": "lint-staged",
    "pretest": "node scripts/rebuild-native.js --node",
    "test": "vitest run",
    "pretest:watch": "node scripts/rebuild-native.js --node",
    "test:watch": "vitest",
    "changelog": "git-cliff -o CHANGELOG.md",
    "changelog:latest": "git-cliff -l -o RELEASE_NOTES.md"
  },
  "lint-staged": {
    "*.{js,ts,vue}": [
      "prettier --write",
      "oxlint"
    ]
  },
  "type": "module",
  "devDependencies": {
    "@iconify-json/material-symbols": "^1.2.54",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/solar": "^1.2.5",
    "@iconify-json/svg-spinners": "^1.2.4",
    "@iconify/vue": "^5.0.0",
    "@types/archiver": "^7.0.0",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^25.2.1",
    "@types/semver": "^7.7.1",
    "@types/steam-user": "^5.1.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "chalk": "^5.6.2",
    "chokidar": "^4.0.3",
    "electron": "^38.2.1",
    "electron-builder": "^26.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "oxlint": "^1.43.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "semver": "^7.7.4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.4"
  },
  "dependencies": {
    "@img/sharp-win32-x64": "^0.34.5",
    "@internationalized/date": "^3.11.0",
    "@kfonts/d2coding": "^0.2.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/vue-query": "^5.92.9",
    "@vueuse/core": "^14.2.0",
    "archiver": "^7.0.1",
    "better-sqlite3": "^12.6.2",
    "chrome-launcher": "^1.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.19",
    "dompurify": "^3.3.2",
    "echarts": "^6.0.0",
    "electron-log": "^5.4.3",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.7.3",
    "electron-window-state": "^5.0.3",
    "fast-glob": "^3.3.3",
    "iconv-lite": "^0.7.1",
    "knex": "^3.1.0",
    "license-checker-rseidelsohn": "^4.4.2",
    "lucide-vue-next": "^0.563.0",
    "marked": "^17.0.4",
    "node-html-parser": "^7.0.2",
    "pinia": "^3.0.4",
    "pretendard": "^1.3.9",
    "puppeteer-core": "^24.37.2",
    "reka-ui": "^2.8.0",
    "sharp": "^0.34.5",
    "steam-user": "^5.3.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "vue": "^3.5.27",
    "vue-echarts": "^8.0.1",
    "vue-router": "4",
    "vue-sonner": "^2.0.9"
  },
  "packageManager": "pnpm@10.28.2",
  "pnpm": {
    "ignoredBuiltDependencies": [
      "esbuild",
      "vue-demi"
    ],
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "better-sqlite3",
      "electron",
      "protobufjs",
      "puppeteer",
      "sharp"
    ],
    "overrides": {
      "node-abi": "^3.78.0"
    }
  }
}
